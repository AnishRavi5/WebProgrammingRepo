	name VARCHAR, 
	password VARCHAR, 
	PRIMARY KEY (id)
)


[no key 0.00004s] ()

CREATE TABLE user (
	id INTEGER NOT NULL, 
	name VARCHAR, 
	password VARCHAR, 
	PRIMARY KEY (id)
)


[no key 0.00008s] ()

CREATE TABLE city (
	id INTEGER NOT NULL, 
	name VARCHAR, 
	url VARCHAR, 
	"adminId" INTEGER, 
	PRIMARY KEY (id), 
	FOREIGN KEY("adminId") REFERENCES admin (id)
)


[no key 0.00009s] ()

CREATE TABLE usercity (
	id INTEGER NOT NULL, 
	"cityId" INTEGER, 
	"userId" INTEGER, 
	year VARCHAR, 
	month VARCHAR, 
	weather_params VARCHAR, 
	PRIMARY KEY (id), 
	FOREIGN KEY("cityId") REFERENCES city (id), 
	FOREIGN KEY("userId") REFERENCES user (id)
)


[no key 0.00007s] ()

