	id INTEGER NOT NULL, 
	year_month_param VARCHAR, 
	"values" VARCHAR, 
	"cityId" INTEGER, 
	PRIMARY KEY (id), 
	FOREIGN KEY("cityId") REFERENCES city (id)
)


